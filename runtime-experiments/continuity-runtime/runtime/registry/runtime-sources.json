      "runtimeProfile": "diagnostics",
      "policy": "repository-aware",
      "capabilities": [
        "repository-context",
        "runtime-observability"
      ]
    },
    {
      "id": "outsetdesign",
      "type": "ecosystem-domain",
      "domains": ["outsetdesign.org"],
      "runtimeProfile": "continuity-heavy",
      "policy": "continuity-enabled",
      "capabilities": [
        "overlay",
        "continuity-export",
        "locality-traversal",
        "runtime-diagnostics"
      ]
    }
  ]
}