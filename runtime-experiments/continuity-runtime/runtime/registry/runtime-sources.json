      "domains": ["chatgpt.com"],
      "runtimeProfile": "lightweight",
      "policy": "safe-lightweight",
      "capabilities": [
        "overlay",
        "continuity-export",
        "runtime-diagnostics"
      ]
    },
    {
      "id": "github",
      "type": "repository-interface",
